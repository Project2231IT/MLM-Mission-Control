server default {
    listen {
        type = auth
        ipaddr = *
        port = 1812
    }

    listen {
        type = acct
        ipaddr = *
        port = 1813
    }

    authorize {
        files
    }

    authenticate {
        Auth-Type Accept {
            ok
        }
    }

    preacct {
        preprocess
    }

    accounting {
        ok
    }
}
